# Full credential instructions + team checklist: see README.md (Table of contents → Team workflow & each Plugin section).
#
# --- Facebook Page (Graph API) ---
FB_PAGE_ID=
FB_PAGE_TOKEN=
# Optional override (default v19.0)
# FB_GRAPH_VERSION=v19.0

# --- Twitter / X (API v2) — use ONE auth method ---
# OAuth 2.0 user access token with tweet.write:
TWITTER_OAUTH2_ACCESS_TOKEN=
# OR OAuth 1.0a user context (all four required if not using OAuth2):
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
# Tweet max length (default 280; X premium allows more)
TWITTER_MAX_CHARS=280

# --- LinkedIn (REST Posts API) ---
LINKEDIN_ACCESS_TOKEN=
# urn:li:person:xxxx or urn:li:organization:xxxx
LINKEDIN_AUTHOR_URN=
# Monthly API version header (default 202405)
# LINKEDIN_VERSION=202405

# --- YouTube (Data API: updates existing video title + description) ---
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_VIDEO_ID=

# --- WhatsApp Business Cloud API (Meta Graph) ---
WHATSAPP_ACCESS_TOKEN=
# Phone number ID from Meta Developer → WhatsApp → API setup
WHATSAPP_PHONE_NUMBER_ID=
# Recipient(s): E.164 digits only, comma-separated (e.g. 15551234567,447700900123)
WHATSAPP_TO=
# Optional Graph version (default v21.0)
# WHATSAPP_GRAPH_VERSION=v21.0

# --- Ollama ---
OLLAMA_URL=http://localhost:11434
MODEL=gemma:7b-instruct

# Comma-separated platforms to publish (when not using --only=)
PLATFORMS=facebook,twitter,linkedin,youtube,whatsapp
